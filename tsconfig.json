{
  "compilerOptions": {
    "moduleResolution": "Node",
    "target": "ESNext",
    "module": "CommonJS",
    "strict": false,
    "lib": ["DOM", "DOM.Iterable", "ES2021"],

    "outDir": "build",
    "baseUrl": ".",

    "paths": {
      "@src/*": ["src/*"],
      "@/*": ["./*"]
    },

    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": false,
    "sourceMap": true,
    "pretty": true,

    "types": ["node"]
  },

  "include": ["src"]
}
